# ──────────────────────────────────────────────────────────────────────────────
# CCTV Service Dashboard API — Environment Variables
# Copy this file to .env and fill in the values.
# ──────────────────────────────────────────────────────────────────────────────

PORT=5000
MONGODB_URI=mongodb://localhost:27017/your_database_name
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# ── Authentication Secrets ────────────────────────────────────────────────────
# IMPORTANT: In production, both JWT_SECRET and OWNER_KEY are REQUIRED and
# must be strong, unique values. The server will refuse to start without them.
#
# Generate a strong JWT_SECRET with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=1d
OWNER_KEY=your_owner_key_here_min_16_chars

# ── Account Security ─────────────────────────────────────────────────────────
# Max failed login attempts before account lockout (default: 5)
MAX_LOGIN_ATTEMPTS=5
# Account lockout duration in ms (default: 900000 = 15 minutes)
ACCOUNT_LOCK_DURATION_MS=900000

# ── Token Expiry ──────────────────────────────────────────────────────────────
# Password reset token expiry in ms (default: 600000 = 10 minutes)
PASSWORD_RESET_EXPIRES_MS=600000
# Email verification token expiry in ms (default: 86400000 = 24 hours)
EMAIL_VERIFY_EXPIRES_MS=86400000

# ── Email / SMTP (optional in development — emails logged to console) ─────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@yourdomain.com
